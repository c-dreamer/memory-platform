# ============================================================
# Memory Platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# All variables match the Python config.py + docker-compose.memory.yml.

# --- Database ---
DATABASE_URL=postgresql://memory:password@memory-postgres:5432/memory
NEON_URL=
NEON_DATABASE_URL=
REDIS_URL=redis://memory-redis:6379/0
NEO4J_URI=bolt://memory-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- API ---
API_KEY=
API_PORT=8000

# --- Embeddings ---
EMBEDDING_MODEL=local
EMBEDDING_DIM=384
NVIDIA_API_KEY=
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embed-qa-4
OPENAI_API_KEY=

# --- Obsidian ---
VAULT_PATH=/vault
OBSIDIAN_API_URL=http://host.docker.internal:27124
OBSIDIAN_API_KEY=

# --- Cache TTLs (seconds) ---
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=3600
CACHE_TTL_LONG=86400

# --- Hybrid Search ---
SEARCH_DEFAULT_MODE=hybrid
RRF_K=20
RRF_VECTOR_WEIGHT=0.6
RRF_KEYWORD_WEIGHT=0.4

# --- Memory Decay (Ebbinghaus-inspired) ---
DECAY_ENABLED=true
DECAY_HALF_LIFE_DAYS=90.0
DECAY_MIN_SCORE=0.1
DECAY_APPLY_TO_SEARCH=true

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_CHUNKS_PER_DOC=100

# --- Logging ---
RUST_LOG=info
