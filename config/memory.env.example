# Copy outside the repository to ~/.config/memory-platform/memory.env and set
# permissions to 600. Never place values in OpenCode/Codex JSON files.
DATABASE_URL=postgresql://memory:password@127.0.0.1:5432/memory
NEON_SYNC_URL=postgresql://USER:PASSWORD@DIRECT-ENDPOINT/neondb?sslmode=require
MEMORY_DEVICE_ID=mac-replace-with-uuid
MEMORY_RUNTIME=homebrew
EMBEDDING_MODEL=nvidia
EMBEDDING_DIM=2048
NVIDIA_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/embeddings
NVIDIA_API_KEY=
VAULT_PATH=/Users/REPLACE/Library/Mobile Documents/iCloud~md~obsidian/Documents/Main Vault
MEMORY_MAIN_VAULT_ROOT=/Users/REPLACE/Library/Mobile Documents/iCloud~md~obsidian/Documents/Main Vault
MEMORY_ARCHIVE_EMBEDDING=disabled
